ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda-11.8/bin/nvcc

cflags = -pthread -B /root/miniconda3/envs/pntr/compiler_compat -Wl,--sysroot=/ -Wsign-compare -DNDEBUG -g -fwrapv -O3 -Wall -Wstrict-prototypes -fPIC -I/root/miniconda3/envs/pntr/lib/python3.7/site-packages/torch/include -I/root/miniconda3/envs/pntr/lib/python3.7/site-packages/torch/include/torch/csrc/api/include -I/root/miniconda3/envs/pntr/lib/python3.7/site-packages/torch/include/TH -I/root/miniconda3/envs/pntr/lib/python3.7/site-packages/torch/include/THC -I/usr/local/cuda-11.8/include -I/root/miniconda3/envs/pntr/include/python3.7m -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=gridding -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++14
cuda_cflags = -I/root/miniconda3/envs/pntr/lib/python3.7/site-packages/torch/include -I/root/miniconda3/envs/pntr/lib/python3.7/site-packages/torch/include/torch/csrc/api/include -I/root/miniconda3/envs/pntr/lib/python3.7/site-packages/torch/include/TH -I/root/miniconda3/envs/pntr/lib/python3.7/site-packages/torch/include/THC -I/usr/local/cuda-11.8/include -I/root/miniconda3/envs/pntr/include/python3.7m -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=gridding -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_70,code=compute_70 -gencode=arch=compute_70,code=sm_70 -std=c++14
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags



build /chenyiming/projects/PoinTr/extensions/gridding/build/temp.linux-x86_64-cpython-37/gridding.o: cuda_compile /chenyiming/projects/PoinTr/extensions/gridding/gridding.cu
build /chenyiming/projects/PoinTr/extensions/gridding/build/temp.linux-x86_64-cpython-37/gridding_cuda.o: compile /chenyiming/projects/PoinTr/extensions/gridding/gridding_cuda.cpp
build /chenyiming/projects/PoinTr/extensions/gridding/build/temp.linux-x86_64-cpython-37/gridding_reverse.o: cuda_compile /chenyiming/projects/PoinTr/extensions/gridding/gridding_reverse.cu





